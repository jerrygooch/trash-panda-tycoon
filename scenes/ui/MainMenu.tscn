layout_mode = 2
size_flags_horizontal = 4
size_flags_vertical = 4
bbcode_enabled = true
text = "Trash items appear on the conveyor belt above.
Drag them into the matching bin below:

[color=#66BB6A]Food (green) → Food bin[/color]
[color=#78909C]Metal (gray) → Metal bin[/color]
[color=#42A5F5]Plastic (blue) → Plastic bin[/color]

Correct sort = [color=#FFD700]+coins[/color]
Wrong sort = [color=#FF5252]+mess[/color]
Mess fills up = round ends early

Complete rounds, buy upgrades,
build your raccoon empire!"
theme_override_font_sizes/font_size = 16
scroll_active = false

